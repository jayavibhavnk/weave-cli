{
  "name": "memweave",
  "version": "0.3.0",
  "description": "Graph-native memory CLI for AI agents — persistent, multi-agent, cross-session context",
  "type": "module",
  "bin": {
    "weave": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "memory",
    "graph",
    "cli",
    "llm",
    "rag",
    "memweave",
    "openai",
    "anthropic",
    "multi-agent",
    "persistent-memory"
  ],
  "author": "jayavibhavnk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jayavibhavnk/memweave"
  },
  "homepage": "https://github.com/jayavibhavnk/memweave#readme",
  "bugs": {
    "url": "https://github.com/jayavibhavnk/memweave/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.85.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
